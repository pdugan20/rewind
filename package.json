{
  "name": "rewind",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.18.0",
    "npm": "11.5.2"
  },
  "packageManager": "npm@11.5.2",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "npm run db:migrate && wrangler dev",
    "deploy": "npm run db:migrate && npm run db:remote && wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:claude": "claudelint",
    "lint:deps": "knip",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:automation-policy": "node --test scripts/automation-policy.test.mjs",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply rewind-db --local",
    "db:remote": "wrangler d1 migrations apply rewind-db --remote",
    "db:studio": "drizzle-kit studio",
    "spec:update": "vitest run src/__tests__/openapi-snapshot.test.ts --update",
    "snapshots:check": "vitest run src/__tests__/openapi-snapshot.test.ts && cd mcp-server && vitest run src/__tests__/manifest-snapshot.test.ts",
    "lint:api": "spectral lint openapi.snapshot.json",
    "www:dev": "cd docs-site && npx astro dev",
    "www:build": "cd docs-site && npx astro build",
    "www:deploy": "cd docs-site && npx astro build && npx wrangler pages deploy dist --project-name rewind-www --commit-dirty=true",
    "docs:dev": "cd docs-mintlify && mint dev",
    "docs:validate": "cd docs-mintlify && mint validate",
    "docs:links": "cd docs-mintlify && mint broken-links",
    "docs:gen-mcp": "tsx scripts/gen-mcp-reference.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pdugan20/rewind.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pdugan20/rewind/issues"
  },
  "homepage": "https://github.com/pdugan20/rewind#readme",
  "dependencies": {
    "@hono/zod-openapi": "^1.5.1",
    "@hono/zod-validator": "^0.9.0",
    "drizzle-orm": "^0.45.1",
    "fast-png": "^8.0.0",
    "hono": "^4.12.31",
    "jpeg-js": "^0.4.4",
    "thumbhash": "^0.1.1",
    "yaml": "2.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.21",
    "@cloudflare/workers-types": "^4.20260310.1",
    "@eslint/js": "^10.0.1",
    "@mozilla/readability": "^0.6.0",
    "@stoplight/spectral-cli": "^6.16.2",
    "@types/jsdom": "^28.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "claude-code-lint": "0.7.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-drizzle": "^0.2.3",
    "fit-file-parser": "^2.3.3",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^5.88.1",
    "lint-staged": "^16.3.3",
    "mint": "4.2.728",
    "prettier": "^3.8.1",
    "tsx": "4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "~3.2.7",
    "wrangler": "^4.72.0"
  },
  "overrides": {
    "undici": "7.28.0",
    "ws": "8.21.0"
  }
}
